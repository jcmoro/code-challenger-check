# ---- Symfony backend ----
APP_ENV=dev
APP_SECRET=change_me_in_real_deployments
APP_DEBUG=1

# Campaign feature flag
CAMPAIGN_ACTIVE=true
CAMPAIGN_PERCENTAGE=5.0

# Provider HTTP timeouts (seconds)
PROVIDER_TIMEOUT_SECONDS=10

# Provider base URLs (all served by the local nginx during dev)
PROVIDER_A_BASE_URL=http://nginx/provider-a
PROVIDER_B_BASE_URL=http://nginx/provider-b
PROVIDER_C_BASE_URL=http://nginx/provider-c

# CORS (Vite dev server origin)
CORS_ALLOW_ORIGIN=http://localhost:5173

# ---- Frontend (Vue / Vite) ----
# Read by Vite at build time; the dev server still proxies through nginx
VITE_API_BASE=http://localhost:8080

# ---- Host port mappings (override if 8080 / 5173 are taken) ----
NGINX_HOST_PORT=8080
VITE_HOST_PORT=5173
